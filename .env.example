# --- SERVER CONFIGURATION ---
PORT=8080
WEB_CLIENT_URL=http://localhost:3000
WEB_SERVER_URL=http://localhost:8080

# --- DATABASE (POSTGRESQL) ---
DB_URL=jdbc:postgresql://localhost:5432/weaver_db
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# --- SECURITY & JWT ---
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET_KEY=your_very_long_and_secure_secret_key_here
JWT_ACCESS_TOKEN_EXPIRATION=86400000
JWT_REFRESH_TOKEN_EXPIRATION=1209600000
JWT_TWO_FA_EXPIRATION=90000
JWT_VERIFICATION_EXPIRATION=900000

# --- EMAIL SERVICE (GMAIL SMTP) ---
EMAIL_APP_USERNAME=your-email@gmail.com
EMAIL_APP_PASSWORD=your-app-password-here

# --- OAUTH2 (GOOGLE) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- RABBITMQ ---
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USERNAME=your-rabbit-username
RABBIT_PASSWORD=your-rabbit-password

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=